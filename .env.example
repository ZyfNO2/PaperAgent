# v0.6 real Mistral executor and smoke tests. Never commit real values.
MISTRAL_API_KEY=
PAPERAGENT_LLM_PROVIDER=mistral
PAPERAGENT_LLM_MODEL=
PAPERAGENT_LLM_BASE_URL=https://api.mistral.ai/v1
PAPERAGENT_LLM_CONNECT_TIMEOUT=5
PAPERAGENT_LLM_READ_TIMEOUT=60
PAPERAGENT_LLM_TOTAL_TIMEOUT=90
PAPERAGENT_LLM_MAX_ATTEMPTS=2
PAPERAGENT_LLM_MAX_INPUT_TOKENS_PER_TASK=32000
PAPERAGENT_LLM_MAX_OUTPUT_TOKENS_PER_CALL=4096
PAPERAGENT_LLM_MAX_OUTPUT_TOKENS_PER_TASK=16384
PAPERAGENT_LLM_MAX_CALLS=12
PAPERAGENT_LLM_TASK_TIMEOUT=600
PAPERAGENT_LLM_MAX_COST_USD=
PAPERAGENT_LLM_PRICE_TABLE=
# Optional OpenAI-compatible reasoning budget. Leave blank for provider defaults.
PAPERAGENT_LLM_REASONING_EFFORT=
PAPERAGENT_RUN_REAL_LLM=0
PAPERAGENT_MISTRAL_MODEL=

# Real literature providers. Never commit API keys.
PAPERAGENT_CONTACT_EMAIL=
OPENALEX_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
PAPERAGENT_RUN_REAL_PROVIDER=0
PAPERAGENT_MAX_PROVIDER_CALLS=48
PAPERAGENT_ENABLE_WEB_SEARCH=0
TAVILY_API_KEY=

# Retrieval resilience. Use offline for pytest/CI replay, cache_first for local development,
# and live only for explicit provider integration checks.
PAPERAGENT_RETRIEVAL_MODE=cache_first
PAPERAGENT_RETRIEVAL_CACHE=.paperagent/retrieval-cache.sqlite3
PAPERAGENT_RETRIEVAL_FIXTURES=
PAPERAGENT_RECORD_RETRIEVAL_FIXTURES=0
PAPERAGENT_PROVIDER_TIMEOUT=10
PAPERAGENT_ARXIV_CONNECT_TIMEOUT=8
PAPERAGENT_ARXIV_READ_TIMEOUT=30
PAPERAGENT_RESULTS_PER_PROVIDER_REQUEST=10
PAPERAGENT_OPENALEX_REQUESTS_PER_MINUTE=120
PAPERAGENT_S2_REQUESTS_PER_MINUTE=48
PAPERAGENT_ARXIV_REQUESTS_PER_MINUTE=18

# Experimental OpenAI-compatible smoke retained from v0.5.1 acceptance.
PAPERAGENT_OPENAI_API_KEY=
PAPERAGENT_OPENAI_BASE_URL=https://api.openai.com/v1
PAPERAGENT_OPENAI_MODEL=gpt-4o-mini
