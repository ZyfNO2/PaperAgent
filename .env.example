# MiniMax (M3) — Anthropic-compatible API
# Official docs: https://platform.minimaxi.com/docs/api-reference/text-anthropic-api
MINIMAX_API_KEY=YOUR_MINIMAX_KEY
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M3
MINIMAX_MAX_TOKENS=4096

# Generic LLM provider (LiteLLM-compatible)
LITELLM_MODEL=minimax/MiniMax-M3

# Re1.3: LLM profile selection
# Default: deepseek (faster, 87-106s/case in Re1.3 v3)
# Alternative: stepfun (step-3.7-flash, RPM=10, slower but functional)
FAST_JSON_PRIMARY=deepseek
LLM_PROFILE=deepseek

# === StepFun ===
STEPFUN_API_KEY=YOUR_STEPFUN_KEY
STEPFUN_MODEL=step-3.7-flash
STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_RPM_LIMIT=10

# === DeepSeek (recommended) ===
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_KEY
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# === Semantic Scholar (optional, for citation expansion) ===
# S2_API_KEY=your_s2_api_key

# === Graph config ===
PAPERAGENT_MAX_REPAIR_ROUNDS=2
VERIFIER_BATCH_SIZE=8
VERIFIER_MAX_WORKERS=4

# FastAPI SQLite path override (default: data/topicpilot.db)
# TOPICPILOT_SQLITE_PATH=./data/topicpilot.db
