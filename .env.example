PAPERAGENT_LLM_MAX_ATTEMPTS=2
PAPERAGENT_LLM_MAX_INPUT_TOKENS_PER_TASK=32000
PAPERAGENT_LLM_MAX_OUTPUT_TOKENS_PER_CALL=4096
