      "result": "pass"
    },
    {
      "step": 2,
      "name": "manual_ingest",
      "action": "POST /api/v1/projects/demo-local-rag/paper-library/manual",
      "request_body": {
        "title": "YOLO Steel Surface Defect Detection Note",
        "text": "This paper studies steel surface defect detection using YOLO. The experiment uses the NEU-DET dataset and reports that lightweight YOLO variants can detect scratches, patches and crazing defects. The method section describes data augmentation and evaluation with precision and recall.",
        "url": null,
        "tags": []
      },
      "response": {
        "paper_id": "paper_mn_*",
        "status": "ingested",
        "parse_status": "parsed",
        "chunk_count": 1,
        "is_duplicate": false,
        "message": "manual 文本已入库 (1 chunks)"
      },
      "ui_selector": "data-testid='library-flash'",
      "ui_assert": "flash contains '已入库'",
      "screenshot": "apps/web-react/e2e/screenshots/session60/s60_add_paper.png",
      "result": "pass"
    },
    {
      "step": 3,
      "name": "list_papers",
      "action": "GET /api/v1/projects/demo-local-rag/paper-library",
      "ui_selector": "data-testid^='library-item-paper_mn_'",
      "ui_assert": "至少 1 个 item, meta 含 paper_id + chunk_count",
      "result": "pass"
    },
    {
      "step": 4,
      "name": "build_index",
      "action": "POST /api/v1/projects/demo-local-rag/paper-library/index",
      "request_body": {"force": false},
      "response": {
        "chunk_count": ">=1",
        "indexed": ">=1",
        "skipped": 0,
        "duration_ms": "<200",
        "paper_count": 1
      },
      "ui_selector": "data-testid='library-flash' + data-testid='library-index-status-paper_mn_*'",
      "ui_assert": "flash 含 '索引完成', status 显示 '已索引'",
      "screenshot": "apps/web-react/e2e/screenshots/session60/s60_index_status.png",
      "result": "pass"
    },
    {
      "step": 5,
      "name": "index_status",
      "action": "GET /api/v1/projects/demo-local-rag/paper-library/index/status",
      "response": {
        "project_id": "demo-local-rag",
        "total_papers": 1,
        "total_chunks": 1,
        "indexed_chunks": 1,
        "unindexed_chunks": 0,
