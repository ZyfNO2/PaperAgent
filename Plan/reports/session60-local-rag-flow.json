      },
      "result": "pass"
    },
    {
      "step": 6,
      "name": "refresh_persist",
      "action": "page.reload()",
      "ui_assert": "列表项仍在 (>=1)",
      "screenshot": "apps/web-react/e2e/screenshots/session60/s60_after_refresh_persisted.png",
      "result": "pass"
    },
    {
      "step": 7,
      "name": "local_ask_hit",
      "action": "POST /api/v1/projects/demo-local-rag/paper-library/local-ask",
      "request_body": {"question": "What dataset does this paper use?", "top_k": 3},
      "response": {
        "question": "What dataset does this paper use?",
        "answer": "根据本地文献库检索, 与问题相关的片段摘录如下: [1] Body: This paper studies steel surface defect detection using YOLO. The experiment uses the NEU-DET dataset...",
        "evidence_refs": [
          {
            "paper_id": "paper_mn_*",
            "chunk_id": "chunk_*",
            "section_title": "Body",
            "chunk_type": "unknown",
            "quote": "This paper studies steel surface defect detection using YOLO. The experiment uses the NEU-DET dataset...",
            "score": 0.343
          }
        ],
        "retrieval_mode": "local_embedding",
        "confidence": 0.343,
        "no_hit": false
      },
      "ui_selector": "data-testid='local-rag-mode' + data-testid='local-rag-answer' + data-testid^='local-rag-ref-'",
      "ui_assert": "mode='local_embedding', answer 含 'NEU-DET', ref.quote 含 'NEU-DET'",
      "screenshot": "apps/web-react/e2e/screenshots/session60/s60_local_rag_answer.png",
      "result": "pass"
    },
    {
