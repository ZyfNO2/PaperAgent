{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '> TopicPilot-CN: 见 CLAUDE.md 阶段开发流程约束'",
            "description": "提醒 agent 项目级规约"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python .claude/hooks/user_completion_check.py 2>&1 || python .claude/hooks/user_completion_check.py 2>&1",
            "description": "Stop 时做用户输入 vs 已交付物 完成度自检"
          }
        ]
      }
    ]
  }
}
