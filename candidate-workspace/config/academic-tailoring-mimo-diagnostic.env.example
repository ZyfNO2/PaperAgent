# Expanded diagnostic profile for mimo-v2.5-free through the Opencode-compatible endpoint.
# Supply PAPERAGENT_OPENAI_API_KEY separately; never commit the credential.
PAPERAGENT_LLM_PROVIDER=deepseek
PAPERAGENT_LLM_MODEL=mimo-v2.5-free
PAPERAGENT_LLM_BASE_URL=https://opencode.ai/zen/v1

# Mimo does not use OpenAI reasoning_effort. Portable schema prompting is required.
PAPERAGENT_LLM_REASONING_EFFORT=
PAPERAGENT_LLM_NATIVE_JSON_SCHEMA=0
PAPERAGENT_LLM_ALLOW_SCHEMA_REPAIR=1

# Diagnostic phase: favor coverage and resilience over cost/latency. These limits are
# intentionally larger than the eventual production profile and should be tightened only
# after retrieval-stage diagnostics identify the actual bottleneck.
PAPERAGENT_LLM_CONNECT_TIMEOUT=15
PAPERAGENT_LLM_READ_TIMEOUT=600
PAPERAGENT_LLM_TOTAL_TIMEOUT=660
PAPERAGENT_LLM_TASK_TIMEOUT=3600
PAPERAGENT_LLM_MAX_ATTEMPTS=3
PAPERAGENT_LLM_MAX_REQUESTS_PER_MINUTE=20
PAPERAGENT_LLM_MAX_INPUT_TOKENS_PER_TASK=524288
PAPERAGENT_LLM_MAX_OUTPUT_TOKENS_PER_CALL=32768
PAPERAGENT_LLM_MAX_OUTPUT_TOKENS_PER_TASK=524288
PAPERAGENT_LLM_MAX_CALLS=60

# Literature retrieval is enabled separately by the benchmark CLI's --enable-web-search.
PAPERAGENT_RUN_REAL_LLM=1
PAPERAGENT_RUN_REAL_PROVIDER=1
PAPERAGENT_ENABLE_WEB_SEARCH=1
