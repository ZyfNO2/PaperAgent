# Academic-tailoring benchmark profile for the Opencode-compatible endpoint.
# Supply PAPERAGENT_OPENAI_API_KEY separately; never commit the credential.
PAPERAGENT_LLM_PROVIDER=deepseek
PAPERAGENT_LLM_MODEL=laguna-s-2.1-free
PAPERAGENT_LLM_BASE_URL=https://opencode.ai/zen/v1

# Laguna is a non-reasoning model. Keep this unset so gateways do not reject an
# OpenAI-specific reasoning parameter that the selected model does not need.
PAPERAGENT_LLM_REASONING_EFFORT=
PAPERAGENT_LLM_NATIVE_JSON_SCHEMA=0

# The full benchmark schema and accumulated per-case context are substantially
# larger than the small provider smoke probes.
PAPERAGENT_LLM_CONNECT_TIMEOUT=10
PAPERAGENT_LLM_READ_TIMEOUT=300
PAPERAGENT_LLM_TOTAL_TIMEOUT=330
PAPERAGENT_LLM_TASK_TIMEOUT=1800
PAPERAGENT_LLM_MAX_ATTEMPTS=1
PAPERAGENT_LLM_MAX_INPUT_TOKENS_PER_TASK=262144
PAPERAGENT_LLM_MAX_OUTPUT_TOKENS_PER_CALL=32768
PAPERAGENT_LLM_MAX_OUTPUT_TOKENS_PER_TASK=262144
PAPERAGENT_LLM_MAX_CALLS=10
