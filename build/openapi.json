                  "type": "null"
                }
              ],
              "title": "Decision"
            }
          },
          {
            "in": "query",
            "name": "favorite",
            "required": false,
            "schema": {
              "default": false,
              "title": "Favorite",
              "type": "boolean"
            }
          }
